# Neon Postgres — create a project at neon.tech, copy the connection string
DATABASE_URL=<your-neon-postgres-url>

# Ollama Cloud — AI runs in-process in the Next.js API routes, so the web app
# needs the key directly. Get one at https://ollama.com (OpenAI-compatible endpoint).
OLLAMA_API_KEY=<your-ollama-key>
# Optional overrides (defaults shown): endpoint and default model tag.
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gpt-oss:20b

# Better-Auth — generate a strong secret
BETTER_AUTH_SECRET=<generate-with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000

# Resend — resend.com (needed for org invitations; use a dummy for local dev)
RESEND_API_KEY=<your-resend-key>

# Liveblocks
LIVEBLOCKS_SECRET_KEY=<your-liveblocks-key>

# Phase 10 — Inngest (function host + event bus)
# Dev: leave both blank to use the local Inngest dev server (npx inngest-cli@latest dev).
# Prod: set both from Inngest Cloud project settings.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
