# Neon Postgres — create a project at neon.tech, copy the connection string
DATABASE_URL=<your-neon-postgres-url>

# Anthropic — platform.anthropic.com
ANTHROPIC_API_KEY=<your-anthropic-key>

# Better-Auth — generate a strong secret
BETTER_AUTH_SECRET=<generate-with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000

# Resend — resend.com (needed for org invitations; use a dummy for local dev)
RESEND_API_KEY=<your-resend-key>
