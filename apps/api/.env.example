# Copy to apps/api/.dev.vars (gitignored) for local `wrangler dev`.
# In production set these with `wrangler secret put <NAME>`.

# Shared HMAC secret used to verify the short-lived token minted by the Next.js
# route handlers. Must match apps/web's API_GATEWAY_SECRET. Min 16 chars.
API_GATEWAY_SECRET=replace-with-shared-gateway-secret

# Base URL of the agents (LangGraph) Node server.
AGENTS_SERVER_URL=http://localhost:4000

# Static bearer token sent to the agents server's /internal/agent-run.
# Must match apps/agents' INTERNAL_AGENT_TOKEN.
INTERNAL_AGENT_TOKEN=replace-with-shared-internal-token
