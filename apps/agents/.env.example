# Copy to apps/agents/.env (gitignored) — loaded by `tsx --env-file=.env`.

# Neon Postgres connection string (same as apps/web) — used to write ai_runs.
DATABASE_URL=postgresql://...

# Anthropic API key — used by @lore/ai / Vercel AI SDK for model calls.
ANTHROPIC_API_KEY=sk-ant-...

# Static bearer token required on /internal/agent-run.
# Must match apps/api's INTERNAL_AGENT_TOKEN.
INTERNAL_AGENT_TOKEN=replace-with-shared-internal-token

# Port the agents server listens on.
PORT=4000
