# Copy to apps/agents/.env (gitignored) — loaded by `tsx --env-file=.env`.

# Neon Postgres connection string (same as apps/web) — used to write ai_runs.
DATABASE_URL=postgresql://...

# Ollama Cloud — used by @lore/ai / Vercel AI SDK for all model calls.
# Get a key at https://ollama.com. The endpoint is OpenAI-compatible.
OLLAMA_API_KEY=
# Optional overrides (defaults shown): endpoint and default model tag.
# If your account exposes a different tag, set OLLAMA_MODEL accordingly.
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gpt-oss:20b

# Static bearer token required on /internal/agent-run.
# Must match apps/api's INTERNAL_AGENT_TOKEN.
INTERNAL_AGENT_TOKEN=replace-with-shared-internal-token

# Port the agents server listens on.
PORT=4000
